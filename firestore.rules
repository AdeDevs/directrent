rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny - Pillar 0
    match /{document=**} {
      allow read, write: if isGodMode();
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isUserSuspended() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) == true;
    }

  function isGodMode() {
    return isSignedIn() && (
      ('email' in request.auth.token && request.auth.token.email != null && request.auth.token.email == 'adeyemiakinyemi01@gmail.com') ||
      request.auth.uid == 'tR7HwQCTvJOLtnKBfKqTTzz3hw82'
    );
  }

  function isAdmin() {
    return isSignedIn() && (
      isGodMode() || 
      (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') in ['admin', 'moderator', 'god', 'admin_staff'])
    );
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isVerified() {
    return isSignedIn() && (
      isGodMode() || 
      ('email_verified' in request.auth.token && request.auth.token.email_verified == true) || 
      ('firebase' in request.auth.token && 'sign_in_provider' in request.auth.token.firebase && request.auth.token.firebase.sign_in_provider == 'phone') ||
      ('phone_number' in request.auth.token && request.auth.token.phone_number != null)
    );
  }

  function isValidId(id) {
     return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
  }

  function isValidModeratorLog(data) {
    return data.keys().hasAll(['moderatorId', 'action', 'targetType', 'targetId', 'createdAt']) &&
           data.moderatorId is string &&
           data.action is string &&
           data.targetType in ['listing', 'agent', 'user'] &&
           data.targetId is string &&
           (data.createdAt == request.time || data.createdAt is timestamp);
  }

  function incoming() {
    return request.resource.data;
  }

  function existing() {
    return resource.data;
  }

    function isValidAnalytics(data) {
      return data.keys().hasAll(['listingId', 'type', 'agentId', 'createdAt']) &&
             data.listingId is string && data.listingId.size() <= 128 &&
             data.type in ['view', 'inquiry', 'save', 'intent_message'] &&
             (data.agentId == null || (data.agentId is string && data.agentId.size() <= 128)) &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    // --- Validation Blueprints (Pillar 2) ---

    function isValidUser(data) {
      return (!('id' in data) || (data.id is string || data.id == null)) &&
             (!('email' in data) || (data.email is string || data.email == null)) &&
             (!('role' in data) || (data.role in ['tenant', 'agent', 'admin', 'moderator'])) &&
             (!('name' in data) || (data.name is string || data.name == null)) &&
             (!('firstName' in data) || (data.firstName is string || data.firstName == null)) &&
             (!('lastName' in data) || (data.lastName is string || data.lastName == null)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string || data.avatarUrl == null)) &&
             (!('gender' in data) || (data.gender is string || data.gender == null)) &&
             (!('dob' in data) || (data.dob is string || data.dob == null)) &&
             (!('nin' in data) || (data.nin is string || data.nin == null)) &&
             (!('city' in data) || (data.city is string || data.city == null)) &&
             (!('country' in data) || (data.country is string || data.country == null)) &&
             (!('about' in data) || (data.about is string || data.about == null)) &&
             (!('theme' in data) || (data.theme in ['light', 'dark'])) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string || data.phoneNumber == null)) &&
             (!('phoneVerified' in data) || (data.phoneVerified is bool)) &&
             (!('verificationLevel' in data) || (data.verificationLevel is string || data.verificationLevel == null)) &&
             (!('verificationStatus' in data) || (data.verificationStatus is string || data.verificationStatus == null)) &&
             (!('favoritesCount' in data) || (data.favoritesCount is number)) &&
             (!('listingsCount' in data) || (data.listingsCount is number)) &&
             (!('completedTxns' in data) || (data.completedTxns is number)) &&
             (!('avgRating' in data) || (data.avgRating is number)) &&
             (!('isSuspended' in data) || (data.isSuspended is bool)) &&
             (!('internalPhone' in data) || (data.internalPhone is string || data.internalPhone == null)) &&
             (!('adminTier' in data) || (data.adminTier is string || data.adminTier == null)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == null || data.updatedAt is map)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt == null || data.createdAt is map)) &&
             (!('lastLogin' in data) || (data.lastLogin is timestamp || data.lastLogin == null || data.lastLogin is map)) &&
             (!('agent' in data) || (data.agent is map));
    }

    function isThemeUpdate() {
      return isSignedIn() && 
             incoming().diff(existing()).affectedKeys().hasOnly(['theme']);
    }

    function isValidListing(data) {
      return data.keys().hasAll(['title', 'priceValue', 'location', 'type', 'image', 'agent']) &&
             data.title is string && data.title.size() <= 200 &&
             data.priceValue is number && data.priceValue >= 0 &&
             data.location is string && data.location.size() <= 300 &&
             data.image is string && data.image.size() <= 1000 &&
             data.agent.id == request.auth.uid &&
             (!('images' in data) || (data.images is list && data.images.size() <= 20)) &&
             (!('amenities' in data) || (data.amenities is list && data.amenities.size() <= 50)) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidConversation(data) {
      return (!('tenantId' in data) || data.tenantId is string || data.tenantId == null) && 
             (!('agentId' in data) || data.agentId is string || data.agentId == null) && 
             (!('listingId' in data) || data.listingId is string || data.listingId == null) &&
             (!('status' in data) || data.status in ['inquiry', 'negotiating', 'contract_requested', 'contract_sent', 'paid', 'completed', 'tour_requested', 'tour_confirmed', 'escrow_locked', 'disputed'] || data.status == null) &&
             (!('unreadCount_tenant' in data) || data.unreadCount_tenant is number || data.unreadCount_tenant == null) &&
             (!('unreadCount_agent' in data) || data.unreadCount_agent is number || data.unreadCount_agent == null) &&
             (!('lastMessage' in data) || data.lastMessage is string || data.lastMessage == null) &&
             (!('tenantName' in data) || data.tenantName is string || data.tenantName == null) &&
             (!('agentName' in data) || data.agentName is string || data.agentName == null) &&
             (!('listingTitle' in data) || data.listingTitle is string || data.listingTitle == null) &&
             (!('listingImage' in data) || data.listingImage is string || data.listingImage == null) &&
             (!('listingPrice' in data) || data.listingPrice is string || data.listingPrice is number || data.listingPrice == null) &&
             (!('listingPriceValue' in data) || data.listingPriceValue is number || data.listingPriceValue == null) &&
             (!('tenantImage' in data) || data.tenantImage is string || data.tenantImage == null) &&
             (!('agentImage' in data) || data.agentImage is string || data.agentImage == null) &&
             (!('id' in data) || data.id is string || data.id == null) &&
             (!('updatedAt' in data) || data.updatedAt == request.time || data.updatedAt is timestamp || data.updatedAt == null);
    }

    function isValidMessage(data) {
       return data.content is string && data.content.size() <= 1048576 &&
              data.senderId == request.auth.uid &&
              (!('createdAt' in data) || data.createdAt == request.time || data.createdAt is timestamp || data.createdAt is map || data.createdAt == null) &&
              (!('type' in data) || data.type in ['text', 'action', 'audio', 'document', 'file']) &&
              (!('actionType' in data) || data.actionType is string || data.actionType == null) &&
              (!('tenantId' in data) || data.tenantId is string || data.tenantId == null) &&
              (!('agentId' in data) || data.agentId is string || data.agentId == null) &&
              (!('fileName' in data) || data.fileName is string || data.fileName == null) &&
              (!('fileSize' in data) || data.fileSize is string || data.fileSize == null) &&
              (!('fileType' in data) || data.fileType is string || data.fileType == null) &&
              (!('duration' in data) || data.duration is number || data.duration == null);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string && 
             data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 1000 &&
             data.type in ['message', 'verification', 'listing', 'system'] &&
             data.read == false &&
             data.createdAt == request.time &&
             (!('link' in data) || data.link == null || data.link is string) &&
             (!('relatedId' in data) || data.relatedId == null || data.relatedId is string);
    }

    // --- Collections ---

    // Public Listings
    match /listings/{listingId} {
      allow list, get: if true;
      allow create: if isSignedIn() && !isUserSuspended() && isValidId(listingId) && isValidListing(incoming()) && (
        isAdmin() || (
          incoming().agent.id == request.auth.uid && (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('verificationLevel', 'none') == 'verified' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('listingsCount', 0) < 5
            )
          )
        )
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (!isUserSuspended() && (
          // Action: Agent Edit
          (existing().agent.id == request.auth.uid && incoming().agent.id == existing().agent.id) ||
          // Action: Engagement Incr (Public)
          (incoming().diff(existing()).affectedKeys().hasOnly(['viewCount', 'favoritesCount', 'inquiryCount', 'updatedAt'])) ||
          // Action: Mark as completed via Transaction
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        ))
      );
      allow delete: if isAdmin() || (isSignedIn() && !isUserSuspended() && existing().agent.id == request.auth.uid);
    }

    // User Profiles (Pillar 6 Hardening)
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (
        isAdmin() ||
        (isOwner(userId) && isValidUser(incoming()) && 
          (!('isSuspended' in incoming().diff(existing()).affectedKeys())) &&
          (!('role' in incoming().diff(existing()).affectedKeys()) || incoming().get('role', '') == existing().get('role', '')) &&
          (!('email' in incoming().diff(existing()).affectedKeys()) || incoming().get('email', '') == existing().get('email', ''))
        ) ||
        (isSignedIn() && !isUserSuspended() && incoming().diff(existing()).affectedKeys().hasOnly(['completedTxns', 'updatedAt', 'avgRating', 'reviewsCount']))
      );
      allow delete: if isAdmin();

      match /favorites/{listingId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) && isValidId(listingId);
        allow delete: if isAdmin();
      }
    }

    match /conversations/{convId} {
      allow read, write: if isSignedIn();

      match /messages/{msgId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && isValidMessage(incoming());
        allow delete: if isSignedIn();
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && !isUserSuspended() && incoming().tenantId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Tours (Pillar 8 Hardening)
    match /tours/{tourId} {
      allow read: if isSignedIn() && (isAdmin() || (!isUserSuspended() && (resource.data.tenantId == request.auth.uid || resource.data.agentId == request.auth.uid)));
      allow create: if isSignedIn() && !isUserSuspended() && incoming().tenantId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || (!isUserSuspended() && (resource.data.tenantId == request.auth.uid || resource.data.agentId == request.auth.uid)));
      allow delete: if isAdmin();
    }

    // Verifications (Pillar 6)
    match /verifications/{verifyId} {
      allow create: if isSignedIn() && !isUserSuspended() && incoming().userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && !isUserSuspended() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // Notifications (Pillar 8)
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Reports
    match /reports/{reportId} {
      allow create: if isSignedIn() || incoming().reporterId == 'anonymous';
      allow read, write: if isAdmin();
    }

    // Moderator Logs
    match /moderatorLogs/{logId} {
      allow create: if isAdmin() && isValidModeratorLog(incoming());
      allow list, get: if isAdmin();
    }

    // Analytics (Pillar 7)
    match /analytics/{analyticsId} {
      allow create: if isSignedIn() && isValidId(analyticsId) && isValidAnalytics(incoming());
      allow list, get, delete: if isAdmin() || (isSignedIn() && resource.data.agentId == request.auth.uid);
    }

    // Vault (Pillar 6)
    match /vault/{vaultId} {
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && !isUserSuspended() && incoming().userId == request.auth.uid && 
                    (incoming().createdAt == request.time || !('createdAt' in incoming()));
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Transactions
    match /transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isAdmin() || (!isUserSuspended() && (resource.data.tenantId == request.auth.uid || resource.data.agentId == request.auth.uid || incoming().tenantId == request.auth.uid || incoming().agentId == request.auth.uid)));
      allow delete: if isAdmin();
    }
  }
}
