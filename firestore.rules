rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // Temporarily allowing unverified emails for development ease. 
      // Re-enable in production for Pillar 6/9 compliance.
      return true; 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return (!('id' in data) || data.id == request.auth.uid) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('role' in data) || data.role in ['tenant', 'agent']) &&
             (!('city' in data) || (data.city is string && data.city.size() <= 100)) &&
             (!('country' in data) || (data.country is string && data.country.size() <= 100)) &&
             (!('nin' in data) || (data.nin is string && data.nin.size() <= 20)) &&
             (!('gender' in data) || (data.gender is string && data.gender.size() <= 20)) &&
             (!('age' in data) || (data.age is string && data.age.size() <= 10)) &&
             (!('avatarUrl' in data) || (data.avatarUrl is string && data.avatarUrl.size() <= 1100000)) && // ~1MB
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (!('phoneVerified' in data) || data.phoneVerified is bool) &&
             (!('verificationLevel' in data) || (data.verificationLevel is string && data.verificationLevel in ["Unverified", "Verified", "Trusted", "Fully Verified"])) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // --- Conversation Validation ---
    function isValidConversation(data) {
      return (!('tenantId' in data) || (data.tenantId is string && data.tenantId.size() > 0)) &&
             (!('agentId' in data) || (data.agentId is string && data.agentId.size() > 0)) &&
             (!('listingId' in data) || (data.listingId is string && data.listingId.size() > 0)) &&
             (!('status' in data) || (data.status is string && data.status in ['inquiry', 'negotiating', 'contract_requested', 'contract_sent', 'paid', 'completed'])) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }


    // --- Message Validation ---
    function isValidMessage(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.senderId == request.auth.uid &&
             data.tenantId is string && data.agentId is string &&
             (data.type == null || data.type == "text" || data.type == "action") &&
             (data.tenantId == request.auth.uid || data.agentId == request.auth.uid) &&
             data.createdAt == request.time;
    }

    // --- Review Validation ---
    function isValidReview(data) {
      return data.tenantId == request.auth.uid &&
             data.agentId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() >= 5 && data.comment.size() <= 500 &&
             data.listingId is string &&
             data.createdAt == request.time;
    }

    // --- Favorite Validation ---
    function isValidFavorite(data) {
      return data.listingId is string &&
             data.createdAt == request.time;
    }

    // --- Resources ---

    // Reviews
    match /reviews/{reviewId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update, delete: if false; // Reviews are immutable once posted
    }
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if true; // Allowed to support "No account found" feedback during login
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()); 

      // Favorites Subcollection
      match /favorites/{listingId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavorite(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // Conversations
    match /conversations/{convId} {
      // Relaxed get to allow checking for existence (!convDoc.exists()) 
      allow get: if isSignedIn(); 
      // Allow listing completed transactions for verified track record
      allow list: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.agentId == request.auth.uid ||
        resource.data.status == 'completed'
      );
      allow create: if isSignedIn() && isEmailVerified() && isValidConversation(incoming()) && incoming().tenantId == request.auth.uid;
      allow update: if isSignedIn() && isEmailVerified() && (existing().tenantId == request.auth.uid || existing().agentId == request.auth.uid) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'status']) &&
                    incoming().updatedAt == request.time;
      
      match /messages/{msgId} {
        allow list, get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.agentId == request.auth.uid);
        allow create: if isSignedIn() && (incoming().tenantId == request.auth.uid || incoming().agentId == request.auth.uid) && isValidMessage(incoming());
      }
    }
  }
}
