rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // Temporarily allowing unverified emails for development ease. 
      // Re-enable in production for Pillar 6/9 compliance.
      return true; 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.id == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 100 &&
             data.role in ['tenant', 'agent'] &&
             (!('city' in data) || data.city is string) &&
             (!('country' in data) || data.country is string) &&
             (!('nin' in data) || (data.nin is string && data.nin.size() <= 20));
    }

    // --- Conversation Validation ---
    function isValidConversation(data) {
      return data.tenantId is string && data.agentId is string && data.listingId is string &&
             data.tenantName is string && data.agentName is string &&
             (data.status == "inquiry" || data.status == "negotiating" || data.status == "contract_requested" || data.status == "contract_sent" || data.status == "paid" || data.status == "completed") &&
             (data.tenantId == request.auth.uid || data.agentId == request.auth.uid);
    }


    // --- Message Validation ---
    function isValidMessage(data) {
      return data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.senderId == request.auth.uid &&
             data.tenantId is string && data.agentId is string &&
             (data.type == null || data.type == "text" || data.type == "action") &&
             (data.tenantId == request.auth.uid || data.agentId == request.auth.uid) &&
             data.createdAt == request.time;
    }

    // --- Review Validation ---
    function isValidReview(data) {
      return data.tenantId == request.auth.uid &&
             data.agentId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() >= 5 && data.comment.size() <= 500 &&
             data.listingId is string &&
             data.createdAt == request.time;
    }

    // --- Favorite Validation ---
    function isValidFavorite(data) {
      return data.listingId is string &&
             data.createdAt == request.time;
    }

    // --- Resources ---

    // Reviews
    match /reviews/{reviewId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update, delete: if false; // Reviews are immutable once posted
    }
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if true; // Allowed to support "No account found" feedback during login
      allow create: if isOwner(userId) && isValidUser(incoming()) && isEmailVerified();
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().role == existing().role && isEmailVerified(); 

      // Favorites Subcollection
      match /favorites/{listingId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFavorite(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // Conversations
    match /conversations/{convId} {
      // Relaxed get to allow checking for existence (!convDoc.exists()) 
      allow get: if isSignedIn(); 
      // Allow listing completed transactions for verified track record
      allow list: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.agentId == request.auth.uid ||
        resource.data.status == 'completed'
      );
      allow create: if isSignedIn() && isEmailVerified() && isValidConversation(incoming()) && incoming().tenantId == request.auth.uid;
      allow update: if isSignedIn() && isEmailVerified() && (existing().tenantId == request.auth.uid || existing().agentId == request.auth.uid) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt', 'status']) &&
                    incoming().updatedAt == request.time;
      
      // Messages Subcollection
      match /messages/{msgId} {
        allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.agentId == request.auth.uid);
        // Removed parent get() lookup to avoid race conditions and permissions issues on new threads
        allow create: if isSignedIn() && isEmailVerified() && isValidMessage(incoming());
      }
    }
  }
}
